<div class="max-w-xl">
  <div class="flex items-center gap-3 mb-6">
    <%= link_to uploads_path, class: "text-slate-400 hover:text-slate-600 transition" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    <% end %>
    <h1 class="text-xl font-bold text-slate-800">ファイルをアップロード</h1>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 p-6">
    <%= form_with model: @upload, url: uploads_path do |form| %>
      <% if @upload.errors.any? %>
        <div class="mb-5 p-4 bg-red-50 border border-red-200 rounded-lg">
          <ul class="list-disc list-inside text-red-600 text-sm space-y-1">
            <% @upload.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-5">
        <%= form.label :file, "ファイル", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
        <div class="border-2 border-dashed border-slate-300 hover:border-indigo-400 rounded-xl p-8 text-center transition cursor-pointer"
             onclick="document.getElementById('upload_file').click()">
          <svg class="w-10 h-10 text-slate-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
          </svg>
          <p class="text-slate-500 text-sm">クリックしてファイルを選択</p>
          <p class="text-slate-400 text-xs mt-1">どんなファイルでもアップロード可能です</p>
          <%= form.file_field :file, required: true, class: "hidden", id: "upload_file",
              onchange: "document.getElementById('file-name').textContent = this.files[0]?.name || ''" %>
        </div>
        <p id="file-name" class="text-sm text-indigo-600 mt-2 font-medium"></p>
      </div>

      <div class="mb-5">
        <%= form.label :title, "タイトル", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
        <%= form.text_field :title, placeholder: "省略するとファイル名が使われます",
            class: "w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-slate-900 text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" %>
      </div>

      <div class="mb-6">
        <%= form.label :description, "メモ", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
        <%= form.text_area :description, rows: 3, placeholder: "任意のメモを残せます",
            class: "w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-slate-900 text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition resize-none" %>
      </div>

      <%= form.submit "アップロード",
          class: "w-full bg-indigo-600 hover:bg-indigo-500 active:bg-indigo-700 text-white font-semibold py-2.5 rounded-lg text-sm transition cursor-pointer" %>
    <% end %>
  </div>
</div>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-xl font-bold text-slate-800">すべてのファイル</h1>
  <%= link_to new_upload_path,
      class: "flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
    </svg>
    アップロード
  <% end %>
</div>

<% if @uploads.empty? %>
  <div class="flex flex-col items-center justify-center h-64 text-center">
    <div class="w-16 h-16 bg-slate-200 rounded-full flex items-center justify-center mb-4">
      <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
      </svg>
    </div>
    <p class="text-slate-500 font-medium">ファイルがありません</p>
    <p class="text-slate-400 text-sm mt-1">最初のファイルをアップロードしてみましょう</p>
    <%= link_to "アップロードする", new_upload_path, class: "mt-4 text-indigo-600 hover:text-indigo-500 text-sm font-medium underline" %>
  </div>
<% else %>
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-slate-50 border-b border-slate-200">
        <tr>
          <th class="text-left px-4 py-3 font-medium text-slate-600">ファイル名</th>
          <th class="text-left px-4 py-3 font-medium text-slate-600">種類</th>
          <th class="text-left px-4 py-3 font-medium text-slate-600">サイズ</th>
          <th class="text-left px-4 py-3 font-medium text-slate-600">日時</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @uploads.each do |upload| %>
          <tr class="hover:bg-slate-50 transition">
            <td class="px-4 py-3">
              <%= link_to upload_path(upload), class: "flex items-center gap-3 group" do %>
                <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0
                    <%= upload.image? ? 'bg-purple-100' : upload.pdf? ? 'bg-red-100' : upload.video? ? 'bg-blue-100' : 'bg-slate-100' %>">
                  <% if upload.image? %>
                    <svg class="w-5 h-5 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  <% elsif upload.pdf? %>
                    <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                    </svg>
                  <% elsif upload.video? %>
                    <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.277A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                    </svg>
                  <% else %>
                    <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                  <% end %>
                </div>
                <div>
                  <p class="font-medium text-slate-800 group-hover:text-indigo-600 transition">
                    <%= upload.title.presence || upload.file.filename %>
                  </p>
                  <% if upload.description.present? %>
                    <p class="text-slate-400 text-xs truncate max-w-xs"><%= upload.description %></p>
                  <% end %>
                </div>
              <% end %>
            </td>
            <td class="px-4 py-3 text-slate-500">
              <%= upload.file.content_type&.split("/")&.last&.upcase %>
            </td>
            <td class="px-4 py-3 text-slate-500">
              <%= number_to_human_size(upload.file.byte_size) %>
            </td>
            <td class="px-4 py-3 text-slate-500">
              <%= upload.created_at.strftime("%Y/%m/%d %H:%M") %>
            </td>
            <td class="px-4 py-3 text-right">
              <%= button_to upload_path(upload), method: :delete,
                  data: { turbo_confirm: "「#{upload.title.presence || upload.file.filename}」を削除しますか？" },
                  class: "text-slate-400 hover:text-red-500 transition cursor-pointer bg-transparent border-0 p-1" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

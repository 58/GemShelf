<div class="max-w-2xl">
  <div class="flex items-center gap-3 mb-6">
    <%= link_to uploads_path, class: "text-slate-400 hover:text-slate-600 transition" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    <% end %>
    <h1 class="text-xl font-bold text-slate-800 truncate">
      <%= @upload.title.presence || @upload.file.filename %>
    </h1>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <%# プレビュー %>
    <% if @upload.image? %>
      <div class="bg-slate-50 border-b border-slate-200 flex items-center justify-center p-4 max-h-96">
        <%= image_tag url_for(@upload.file), class: "max-h-80 max-w-full object-contain rounded" %>
      </div>
    <% elsif @upload.video? %>
      <div class="bg-black">
        <video controls class="w-full max-h-80">
          <source src="<%= url_for(@upload.file) %>" type="<%= @upload.file.content_type %>">
        </video>
      </div>
    <% end %>

    <%# 情報 %>
    <div class="p-6">
      <dl class="grid grid-cols-2 gap-4 text-sm mb-6">
        <div>
          <dt class="text-slate-400 text-xs font-medium uppercase tracking-wider mb-1">ファイル名</dt>
          <dd class="text-slate-800 font-medium"><%= @upload.file.filename %></dd>
        </div>
        <div>
          <dt class="text-slate-400 text-xs font-medium uppercase tracking-wider mb-1">種類</dt>
          <dd class="text-slate-800"><%= @upload.file.content_type %></dd>
        </div>
        <div>
          <dt class="text-slate-400 text-xs font-medium uppercase tracking-wider mb-1">サイズ</dt>
          <dd class="text-slate-800"><%= number_to_human_size(@upload.file.byte_size) %></dd>
        </div>
        <div>
          <dt class="text-slate-400 text-xs font-medium uppercase tracking-wider mb-1">アップロード日時</dt>
          <dd class="text-slate-800"><%= @upload.created_at.strftime("%Y/%m/%d %H:%M") %></dd>
        </div>
        <% if @upload.description.present? %>
          <div class="col-span-2">
            <dt class="text-slate-400 text-xs font-medium uppercase tracking-wider mb-1">メモ</dt>
            <dd class="text-slate-800"><%= @upload.description %></dd>
          </div>
        <% end %>
      </dl>

      <div class="flex items-center gap-3">
        <%= link_to url_for(@upload.file), download: @upload.file.filename,
            class: "flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          ダウンロード
        <% end %>

        <%= button_to upload_path(@upload), method: :delete,
            data: { turbo_confirm: "このファイルを削除しますか？" },
            class: "flex items-center gap-2 bg-red-50 hover:bg-red-100 text-red-600 text-sm font-medium px-4 py-2 rounded-lg transition cursor-pointer border-0" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
          削除
        <% end %>
      </div>
    </div>
  </div>
</div>

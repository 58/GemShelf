<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Gem Shelf" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Gem Shelf">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="bg-slate-900 border-b border-slate-700 fixed w-full top-0 z-10">
      <div class="container mx-auto px-5 py-3 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <div class="w-7 h-7 bg-indigo-500 rounded-lg flex items-center justify-center">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
            </svg>
          </div>
          <%= link_to "GemShelf", root_path, class: "text-lg font-bold text-white" %>
        </div>
        <div class="flex items-center gap-4 text-sm">
          <% if authenticated? %>
            <%= button_to "ログアウト", session_path, method: :delete, class: "text-slate-400 hover:text-white cursor-pointer bg-transparent border-0 font-medium transition" %>
          <% else %>
            <%= link_to "ログイン", root_path, class: "text-slate-400 hover:text-white font-medium transition" %>
          <% end %>
        </div>
      </div>
    </nav>
    <main class="container mx-auto mt-20 px-5 flex pt-8">
      <%= yield %>
    </main>
  </body>
</html>
